{
  "name": "n8n-nodes-pdf-splitter",
  "version": "0.1.1",
  "description": "Split PDF files into multiple parts by page count",
  "license": "MIT",
  "homepage": "https://tiborbosma.nl",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "pdf",
    "split",
    "binary",
    "document"
  ],
  "author": {
    "name": "Tibor Bosma",
    "email": "tibor@tiborbosma.nl",
    "url": "https://tiborbosma.nl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tiborbosma/n8n-nodes-pdf-splitter.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [],
    "nodes": [
      "dist/nodes/PdfSplitter/PdfSplitter.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "n8n-workflow": "^2.13.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
